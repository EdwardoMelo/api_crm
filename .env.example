# ── Database (MySQL) ─────────────────────────────────────────
DATABASE_URL="mysql://user:password@127.0.0.1:3306/crm_dev"
DATABASE_TEST_URL="mysql://user:password@127.0.0.1:3306/crm_test"

# ── Application ──────────────────────────────────────────────
PORT=5001
NODE_ENV=development
# URL pública (produção ou ngrok em dev)
API_PUBLIC_URL=https://your-public-api.example.com
# API do ngrok local (agent) — usado por npm run test:e2e
NGROK_API_URL=http://127.0.0.1:4040
CORS_ALLOW_ALL=true
DEFAULT_TENANT_ID=1

# ── Auth (JWT) ───────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── SMTP (Nodemailer) ────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@example.com
SMTP_PASS=changeme
EMAIL_FROM=no-reply@example.com

# ── Firebase Storage ─────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# ── RabbitMQ (fila de campanhas de e-mail em massa) ──────────
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672
RABBITMQ_CAMPAIGN_QUEUE=crm.email.campaign
RABBITMQ_PREFETCH=1
EMAIL_CAMPAIGN_MAX_ATTEMPTS=3
EMAIL_CAMPAIGN_RETRY_DELAY_MS=2000
# Publicação em lotes (evita estourar memória/conexão da VPS)
EMAIL_CAMPAIGN_PUBLISH_BATCH_SIZE=100
EMAIL_CAMPAIGN_PUBLISH_BATCH_DELAY_MS=200
