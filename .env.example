# ── Database (MySQL) ─────────────────────────────────────────
DATABASE_URL="mysql://user:password@127.0.0.1:3306/crm_dev"
DATABASE_TEST_URL="mysql://user:password@127.0.0.1:3306/crm_test"

# ── Application ──────────────────────────────────────────────
PORT=5001
NODE_ENV=development
CORS_ALLOW_ALL=true
DEFAULT_TENANT_ID=1

# ── Auth (JWT) ───────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── SMTP (Nodemailer) ────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@example.com
SMTP_PASS=changeme
EMAIL_FROM=no-reply@example.com
