generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Client {
  id               Int               @id @default(autoincrement())
  nome             String
  email            String
  telefone         String?
  empresa          String?
  documento        String?
  observacoes      String?           @db.Text
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tenantId         Int
  createdBy        String            @default("system") @db.VarChar(20)
  updatedBy        String            @default("system") @db.VarChar(20)
  budgets          Budget[]
  cashFlows        CashFlow[]
  tenants          tenants           @relation(fields: [tenantId], references: [id])
  fixedIncomes     FixedIncome[]
  installmentPlans InstallmentPlan[]
  projects         Project[]

  @@index([nome])
  @@index([email])
  @@index([tenantId])
  @@index([createdBy])
  @@map("clients")
}

model Employee {
  id               Int               @id @default(autoincrement())
  nome             String
  email            String
  telefone         String?
  cargo            String?
  tipoContratacao  TipoContratacao
  salarioBase      Decimal?          @db.Decimal(12, 2)
  ativo            Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tenantId         Int
  createdBy        String            @default("system") @db.VarChar(20)
  updatedBy        String            @default("system") @db.VarChar(20)
  cashFlows        CashFlow[]
  tenants          tenants           @relation(fields: [tenantId], references: [id])
  fixedExpenses    FixedExpense[]
  installmentPlans InstallmentPlan[]

  @@index([nome])
  @@index([tipoContratacao])
  @@index([ativo])
  @@index([tenantId])
  @@index([createdBy])
  @@map("employees")
}

model Budget {
  id           Int           @id @default(autoincrement())
  clienteId    Int
  titulo       String
  descricao    String?       @db.Text
  valor        Decimal       @db.Decimal(12, 2)
  status       BudgetStatus  @default(RASCUNHO)
  dataValidade DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tenantId     Int
  createdBy    String        @default("system") @db.VarChar(20)
  updatedBy    String        @default("system") @db.VarChar(20)
  budget_files budget_files?
  cliente      Client        @relation(fields: [clienteId], references: [id])
  tenants      tenants       @relation(fields: [tenantId], references: [id])
  email_logs   EmailLog[]
  project      Project?

  @@index([clienteId])
  @@index([status])
  @@index([tenantId])
  @@index([createdBy])
  @@map("budgets")
}

model Project {
  id               Int               @id @default(autoincrement())
  clienteId        Int
  budgetId         Int?              @unique
  titulo           String
  descricao        String?           @db.Text
  valorTotal       Decimal           @db.Decimal(12, 2)
  status           ProjectStatus     @default(PLANEJADO)
  dataInicio       DateTime?
  dataFimPrevista  DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tenantId         Int
  createdBy        String            @default("system") @db.VarChar(20)
  updatedBy        String            @default("system") @db.VarChar(20)
  cashFlows        CashFlow[]
  fixedIncomes     FixedIncome[]
  installmentPlans InstallmentPlan[]
  project_files    project_files[]
  budget           Budget?           @relation(fields: [budgetId], references: [id])
  cliente          Client            @relation(fields: [clienteId], references: [id])
  tenants          tenants           @relation(fields: [tenantId], references: [id])

  @@index([clienteId])
  @@index([status])
  @@index([tenantId])
  @@index([createdBy])
  @@map("projects")
}

model CashFlow {
  id                    Int                  @id @default(autoincrement())
  descricao             String
  valor                 Decimal              @db.Decimal(12, 2)
  tipo                  CashFlowType
  status                CashFlowStatus       @default(PENDENTE)
  dataCompetencia       DateTime
  dataPagamento         DateTime?
  categoria             String?
  projectId             Int?
  clientId              Int?
  employeeId            Int?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  tenantId              Int
  notaFiscalFileName    String?              @db.VarChar(255)
  notaFiscalStoragePath String?              @db.VarChar(512)
  notaFiscalMimeType    String?              @db.VarChar(127)
  notaFiscalSizeBytes   Int?
  createdBy             String               @default("system") @db.VarChar(20)
  updatedBy             String               @default("system") @db.VarChar(20)
  sourceType            CashFlowSourceType   @default(MANUAL)
  fixedExpenseId        Int?
  fixedIncomeId         Int?
  installmentPlanItemId Int?                 @unique
  client                Client?              @relation(fields: [clientId], references: [id])
  employee              Employee?            @relation(fields: [employeeId], references: [id])
  fixedExpense          FixedExpense?        @relation(fields: [fixedExpenseId], references: [id])
  fixedIncome           FixedIncome?         @relation(fields: [fixedIncomeId], references: [id])
  installmentPlanItem   InstallmentPlanItem? @relation(fields: [installmentPlanItemId], references: [id])
  project               Project?             @relation(fields: [projectId], references: [id])
  tenants               tenants              @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, fixedExpenseId, dataCompetencia], map: "cash_flows_tenant_fixed_expense_competence_key")
  @@unique([tenantId, fixedIncomeId, dataCompetencia], map: "cash_flows_tenant_fixed_income_competence_key")
  @@index([tipo])
  @@index([status])
  @@index([dataCompetencia])
  @@index([projectId])
  @@index([clientId])
  @@index([employeeId])
  @@index([tenantId])
  @@index([createdBy])
  @@index([fixedExpenseId])
  @@index([fixedIncomeId])
  @@index([sourceType])
  @@map("cash_flows")
}

model EmailLog {
  id                     Int                     @id @default(autoincrement())
  destinatario           String
  assunto                String
  conteudo               String                  @db.Text
  status                 EmailStatus             @default(PENDENTE)
  dataEnvio              DateTime?
  createdAt              DateTime                @default(now())
  tenantId               Int
  createdBy              String                  @default("system") @db.VarChar(20)
  updatedBy              String                  @default("system") @db.VarChar(20)
  budgetId               Int?
  templateId             Int?
  modoAnexo              email_logs_modoAnexo?
  budgets                Budget?                 @relation(fields: [budgetId], references: [id])
  budget_email_templates budget_email_templates? @relation(fields: [templateId], references: [id])
  tenants                tenants                 @relation(fields: [tenantId], references: [id])

  @@index([destinatario])
  @@index([status])
  @@index([tenantId])
  @@index([createdBy])
  @@index([budgetId], map: "email_logs_budgetId_fkey")
  @@index([templateId], map: "email_logs_templateId_fkey")
  @@map("email_logs")
}

model tenants {
  id                     Int                      @id @default(autoincrement())
  nome                   String
  slug                   String                   @unique
  ativo                  Boolean                  @default(true)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  tipo                   tenants_tipo             @default(EMPRESA)
  createdBy              String                   @default("system") @db.VarChar(20)
  updatedBy              String                   @default("system") @db.VarChar(20)
  budget_email_templates budget_email_templates[]
  budget_files           budget_files[]
  budgets                Budget[]
  cash_flows             CashFlow[]
  clients                Client[]
  email_logs             EmailLog[]
  employees              Employee[]
  fixedExpenses          FixedExpense[]
  fixedIncomes           FixedIncome[]
  installmentPlanItems   InstallmentPlanItem[]
  installmentPlans       InstallmentPlan[]
  project_files          project_files[]
  projects               Project[]
  tenant_fiscal_info     tenant_fiscal_info?
  users                  users[]

  @@index([ativo])
  @@index([nome])
  @@index([createdBy])
}

model users {
  id           Int        @id @default(autoincrement())
  tenantId     Int
  nome         String
  email        String     @unique
  passwordHash String
  role         users_role @default(USUARIO)
  ativo        Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  createdBy    String     @default("system") @db.VarChar(20)
  updatedBy    String     @default("system") @db.VarChar(20)
  tenants      tenants    @relation(fields: [tenantId], references: [id])

  @@index([ativo])
  @@index([email])
  @@index([tenantId])
  @@index([createdBy])
}

model project_files {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  projectId   Int
  fileName    String   @db.VarChar(255)
  storagePath String   @db.VarChar(512)
  mimeType    String   @db.VarChar(127)
  sizeBytes   Int
  createdAt   DateTime @default(now())
  createdBy   String   @default("system") @db.VarChar(20)
  updatedBy   String   @default("system") @db.VarChar(20)
  projects    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenants     tenants  @relation(fields: [tenantId], references: [id])

  @@index([projectId], map: "project_files_projectId_fkey")
  @@index([tenantId, projectId])
  @@index([createdBy])
}

model tenant_fiscal_info {
  id                  Int                                  @id @default(autoincrement())
  tenantId            Int                                  @unique
  razaoSocial         String                               @db.VarChar(255)
  nomeFantasia        String?                              @db.VarChar(255)
  cnpj                String                               @db.VarChar(14)
  inscricaoEstadual   String?                              @db.VarChar(30)
  inscricaoMunicipal  String?                              @db.VarChar(30)
  regimeTributario    tenant_fiscal_info_regimeTributario?
  cnaePrincipal       String?                              @db.VarChar(10)
  emailFiscal         String?                              @db.VarChar(180)
  telefone            String?                              @db.VarChar(20)
  logradouro          String?                              @db.VarChar(255)
  numero              String?                              @db.VarChar(20)
  complemento         String?                              @db.VarChar(100)
  bairro              String?                              @db.VarChar(100)
  cep                 String?                              @db.VarChar(8)
  cidade              String?                              @db.VarChar(100)
  uf                  String?                              @db.Char(2)
  codigoIbgeMunicipio String?                              @db.VarChar(7)
  createdAt           DateTime                             @default(now())
  updatedAt           DateTime
  createdBy           String                               @default("system") @db.VarChar(20)
  updatedBy           String                               @default("system") @db.VarChar(20)
  tenants             tenants                              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([createdBy])
}

model FixedExpense {
  id            Int            @id @default(autoincrement())
  tenantId      Int
  description   String         @db.VarChar(180)
  amount        Decimal        @db.Decimal(12, 2)
  category      String?        @db.VarChar(120)
  dueDayOfMonth Int            @db.UnsignedTinyInt
  startsOn      DateTime       @db.Date
  endsOn        DateTime       @db.Date
  active        Boolean        @default(true)
  employeeId    Int?
  renewedFromId Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  createdBy     String         @default("system") @db.VarChar(20)
  updatedBy     String         @default("system") @db.VarChar(20)
  cashFlows     CashFlow[]
  employee      Employee?      @relation(fields: [employeeId], references: [id])
  renewedFrom   FixedExpense?  @relation("FixedExpenseRenewal", fields: [renewedFromId], references: [id])
  renewals      FixedExpense[] @relation("FixedExpenseRenewal")
  tenants       tenants        @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([active])
  @@index([employeeId])
  @@index([renewedFromId])
  @@index([createdBy])
  @@map("fixed_expenses")
}

model FixedIncome {
  id            Int           @id @default(autoincrement())
  tenantId      Int
  description   String        @db.VarChar(180)
  amount        Decimal       @db.Decimal(12, 2)
  category      String?       @db.VarChar(120)
  dueDayOfMonth Int           @db.UnsignedTinyInt
  startsOn      DateTime      @db.Date
  endsOn        DateTime      @db.Date
  active        Boolean       @default(true)
  clientId      Int?
  projectId     Int?
  renewedFromId Int?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdBy     String        @default("system") @db.VarChar(20)
  updatedBy     String        @default("system") @db.VarChar(20)
  cashFlows     CashFlow[]
  client        Client?       @relation(fields: [clientId], references: [id])
  project       Project?      @relation(fields: [projectId], references: [id])
  renewedFrom   FixedIncome?  @relation("FixedIncomeRenewal", fields: [renewedFromId], references: [id])
  renewals      FixedIncome[] @relation("FixedIncomeRenewal")
  tenants       tenants       @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([active])
  @@index([clientId])
  @@index([projectId])
  @@index([renewedFromId])
  @@index([createdBy])
  @@map("fixed_incomes")
}

model InstallmentPlan {
  id                  Int                   @id @default(autoincrement())
  tenantId            Int
  description         String                @db.VarChar(180)
  type                CashFlowType
  totalAmount         Decimal               @db.Decimal(12, 2)
  installmentCount    Int
  interestRatePercent Decimal?              @db.Decimal(5, 2)
  firstDueDate        DateTime              @db.Date
  category            String?               @db.VarChar(120)
  clientId            Int?
  projectId           Int?
  employeeId          Int?
  status              InstallmentPlanStatus @default(ACTIVE)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  createdBy           String                @default("system") @db.VarChar(20)
  updatedBy           String                @default("system") @db.VarChar(20)
  items               InstallmentPlanItem[]
  client              Client?               @relation(fields: [clientId], references: [id])
  employee            Employee?             @relation(fields: [employeeId], references: [id])
  project             Project?              @relation(fields: [projectId], references: [id])
  tenants             tenants               @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([clientId])
  @@index([projectId])
  @@index([employeeId])
  @@index([createdBy])
  @@map("installment_plans")
}

model InstallmentPlanItem {
  id                Int             @id @default(autoincrement())
  tenantId          Int
  installmentPlanId Int
  installmentNumber Int
  amount            Decimal         @db.Decimal(12, 2)
  dueDate           DateTime        @db.Date
  status            CashFlowStatus  @default(PENDENTE)
  paidAt            DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  createdBy         String          @default("system") @db.VarChar(20)
  updatedBy         String          @default("system") @db.VarChar(20)
  cashFlow          CashFlow?
  installmentPlan   InstallmentPlan @relation(fields: [installmentPlanId], references: [id], onDelete: Cascade)
  tenants           tenants         @relation(fields: [tenantId], references: [id])

  @@unique([installmentPlanId, installmentNumber], map: "installment_plan_items_plan_number_key")
  @@index([tenantId])
  @@index([status])
  @@index([dueDate])
  @@index([createdBy])
  @@map("installment_plan_items")
}

model budget_email_templates {
  id         Int        @id @default(autoincrement())
  tenantId   Int
  nome       String     @db.VarChar(255)
  assunto    String     @db.VarChar(255)
  corpo      String     @db.Text
  variaveis  String     @db.LongText
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @default(now())
  createdBy  String     @default("system") @db.VarChar(20)
  updatedBy  String     @default("system") @db.VarChar(20)
  tenants    tenants    @relation(fields: [tenantId], references: [id])
  email_logs EmailLog[]

  @@unique([tenantId, nome])
}

model budget_files {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  budgetId    Int      @unique
  fileName    String   @db.VarChar(255)
  storagePath String   @db.VarChar(512)
  mimeType    String   @db.VarChar(127)
  sizeBytes   Int
  createdAt   DateTime @default(now())
  createdBy   String   @default("system") @db.VarChar(20)
  updatedBy   String   @default("system") @db.VarChar(20)
  budgets     Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  tenants     tenants  @relation(fields: [tenantId], references: [id])

  @@index([tenantId, budgetId])
}

enum TipoContratacao {
  CLT
  PJ
  FREELANCER
  PARCEIRO
}

enum BudgetStatus {
  RASCUNHO
  ENVIADO
  APROVADO
  REPROVADO
  CANCELADO
  CONVERTIDO
}

enum ProjectStatus {
  PLANEJADO
  EM_ANDAMENTO
  PAUSADO
  CONCLUIDO
  CANCELADO
}

enum CashFlowType {
  ENTRADA
  SAIDA
}

enum CashFlowStatus {
  PENDENTE
  PAGO
  CANCELADO
}

enum CashFlowSourceType {
  MANUAL
  FIXED_EXPENSE
  FIXED_INCOME
  INSTALLMENT
}

enum InstallmentPlanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum EmailStatus {
  PENDENTE
  ENVIADO
  FALHA
}

enum tenant_fiscal_info_regimeTributario {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
  MEI
}

enum tenants_tipo {
  PESSOA_FISICA
  EMPRESA
}

enum users_role {
  ADMIN
  USUARIO
  SYSTEM_ADMIN
}

enum email_logs_modoAnexo {
  ANEXO
  LINK
}
