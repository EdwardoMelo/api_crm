generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Client {
  id          Int        @id @default(autoincrement())
  nome        String
  email       String
  telefone    String?
  empresa     String?
  documento   String?
  observacoes String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenantId    Int
  createdBy   String     @default("system") @db.VarChar(20)
  updatedBy   String     @default("system") @db.VarChar(20)
  budgets     Budget[]
  cashFlows   CashFlow[]
  tenants     tenants    @relation(fields: [tenantId], references: [id])
  projects    Project[]

  @@index([nome])
  @@index([email])
  @@index([tenantId])
  @@index([createdBy])
  @@map("clients")
}

model Employee {
  id              Int             @id @default(autoincrement())
  nome            String
  email           String
  telefone        String?
  cargo           String?
  tipoContratacao TipoContratacao
  salarioBase     Decimal?        @db.Decimal(12, 2)
  ativo           Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  tenantId        Int
  createdBy       String          @default("system") @db.VarChar(20)
  updatedBy       String          @default("system") @db.VarChar(20)
  cashFlows       CashFlow[]
  tenants         tenants         @relation(fields: [tenantId], references: [id])

  @@index([nome])
  @@index([tipoContratacao])
  @@index([ativo])
  @@index([tenantId])
  @@index([createdBy])
  @@map("employees")
}

model Budget {
  id           Int          @id @default(autoincrement())
  clienteId    Int
  titulo       String
  descricao    String?      @db.Text
  valor        Decimal      @db.Decimal(12, 2)
  status       BudgetStatus @default(RASCUNHO)
  dataValidade DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tenantId     Int
  createdBy    String       @default("system") @db.VarChar(20)
  updatedBy    String       @default("system") @db.VarChar(20)
  cliente      Client       @relation(fields: [clienteId], references: [id])
  tenants      tenants      @relation(fields: [tenantId], references: [id])
  project      Project?

  @@index([clienteId])
  @@index([status])
  @@index([tenantId])
  @@index([createdBy])
  @@map("budgets")
}

model Project {
  id              Int             @id @default(autoincrement())
  clienteId       Int
  budgetId        Int?            @unique
  titulo          String
  descricao       String?         @db.Text
  valorTotal      Decimal         @db.Decimal(12, 2)
  status          ProjectStatus   @default(PLANEJADO)
  dataInicio      DateTime?
  dataFimPrevista DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  tenantId        Int
  createdBy       String          @default("system") @db.VarChar(20)
  updatedBy       String          @default("system") @db.VarChar(20)
  cashFlows       CashFlow[]
  project_files   project_files[]
  budget          Budget?         @relation(fields: [budgetId], references: [id])
  cliente         Client          @relation(fields: [clienteId], references: [id])
  tenants         tenants         @relation(fields: [tenantId], references: [id])

  @@index([clienteId])
  @@index([status])
  @@index([tenantId])
  @@index([createdBy])
  @@map("projects")
}

model CashFlow {
  id                    Int            @id @default(autoincrement())
  descricao             String
  valor                 Decimal        @db.Decimal(12, 2)
  tipo                  CashFlowType
  status                CashFlowStatus @default(PENDENTE)
  dataCompetencia       DateTime
  dataPagamento         DateTime?
  categoria             String?
  projectId             Int?
  clientId              Int?
  employeeId            Int?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  tenantId              Int
  notaFiscalFileName    String?        @db.VarChar(255)
  notaFiscalStoragePath String?        @db.VarChar(512)
  notaFiscalMimeType    String?        @db.VarChar(127)
  notaFiscalSizeBytes   Int?
  createdBy             String         @default("system") @db.VarChar(20)
  updatedBy             String         @default("system") @db.VarChar(20)
  client                Client?        @relation(fields: [clientId], references: [id])
  employee              Employee?      @relation(fields: [employeeId], references: [id])
  project               Project?       @relation(fields: [projectId], references: [id])
  tenants               tenants        @relation(fields: [tenantId], references: [id])

  @@index([tipo])
  @@index([status])
  @@index([dataCompetencia])
  @@index([projectId])
  @@index([clientId])
  @@index([employeeId])
  @@index([tenantId])
  @@index([createdBy])
  @@map("cash_flows")
}

model EmailLog {
  id           Int         @id @default(autoincrement())
  destinatario String
  assunto      String
  conteudo     String      @db.Text
  status       EmailStatus @default(PENDENTE)
  dataEnvio    DateTime?
  createdAt    DateTime    @default(now())
  tenantId     Int
  createdBy    String      @default("system") @db.VarChar(20)
  updatedBy    String      @default("system") @db.VarChar(20)
  tenants      tenants     @relation(fields: [tenantId], references: [id])

  @@index([destinatario])
  @@index([status])
  @@index([tenantId])
  @@index([createdBy])
  @@map("email_logs")
}

model tenants {
  id                 Int                 @id @default(autoincrement())
  nome               String
  slug               String              @unique
  ativo              Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime
  tipo               tenants_tipo        @default(EMPRESA)
  createdBy          String              @default("system") @db.VarChar(20)
  updatedBy          String              @default("system") @db.VarChar(20)
  budgets            Budget[]
  cash_flows         CashFlow[]
  clients            Client[]
  email_logs         EmailLog[]
  employees          Employee[]
  project_files      project_files[]
  projects           Project[]
  tenant_fiscal_info tenant_fiscal_info?
  users              users[]

  @@index([ativo])
  @@index([nome])
  @@index([createdBy])
}

model users {
  id           Int        @id @default(autoincrement())
  tenantId     Int
  nome         String
  email        String     @unique
  passwordHash String
  role         users_role @default(USUARIO)
  ativo        Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  createdBy    String     @default("system") @db.VarChar(20)
  updatedBy    String     @default("system") @db.VarChar(20)
  tenants      tenants    @relation(fields: [tenantId], references: [id])

  @@index([ativo])
  @@index([email])
  @@index([tenantId])
  @@index([createdBy])
}

model project_files {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  projectId   Int
  fileName    String   @db.VarChar(255)
  storagePath String   @db.VarChar(512)
  mimeType    String   @db.VarChar(127)
  sizeBytes   Int
  createdAt   DateTime @default(now())
  createdBy   String   @default("system") @db.VarChar(20)
  updatedBy   String   @default("system") @db.VarChar(20)
  projects    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenants     tenants  @relation(fields: [tenantId], references: [id])

  @@index([projectId], map: "project_files_projectId_fkey")
  @@index([tenantId, projectId])
  @@index([createdBy])
}

model tenant_fiscal_info {
  id                  Int                                  @id @default(autoincrement())
  tenantId            Int                                  @unique
  razaoSocial         String                               @db.VarChar(255)
  nomeFantasia        String?                              @db.VarChar(255)
  cnpj                String                               @db.VarChar(14)
  inscricaoEstadual   String?                              @db.VarChar(30)
  inscricaoMunicipal  String?                              @db.VarChar(30)
  regimeTributario    tenant_fiscal_info_regimeTributario?
  cnaePrincipal       String?                              @db.VarChar(10)
  emailFiscal         String?                              @db.VarChar(180)
  telefone            String?                              @db.VarChar(20)
  logradouro          String?                              @db.VarChar(255)
  numero              String?                              @db.VarChar(20)
  complemento         String?                              @db.VarChar(100)
  bairro              String?                              @db.VarChar(100)
  cep                 String?                              @db.VarChar(8)
  cidade              String?                              @db.VarChar(100)
  uf                  String?                              @db.Char(2)
  codigoIbgeMunicipio String?                              @db.VarChar(7)
  createdAt           DateTime                             @default(now())
  updatedAt           DateTime
  createdBy           String                               @default("system") @db.VarChar(20)
  updatedBy           String                               @default("system") @db.VarChar(20)
  tenants             tenants                              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([createdBy])
}

enum TipoContratacao {
  CLT
  PJ
  FREELANCER
  PARCEIRO
}

enum BudgetStatus {
  RASCUNHO
  ENVIADO
  APROVADO
  REPROVADO
  CANCELADO
  CONVERTIDO
}

enum ProjectStatus {
  PLANEJADO
  EM_ANDAMENTO
  PAUSADO
  CONCLUIDO
  CANCELADO
}

enum CashFlowType {
  ENTRADA
  SAIDA
}

enum CashFlowStatus {
  PENDENTE
  PAGO
  CANCELADO
}

enum EmailStatus {
  PENDENTE
  ENVIADO
  FALHA
}

enum users_role {
  ADMIN
  USUARIO
}

enum tenant_fiscal_info_regimeTributario {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
  MEI
}

enum tenants_tipo {
  PESSOA_FISICA
  EMPRESA
}
